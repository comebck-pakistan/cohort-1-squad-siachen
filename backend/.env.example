# Server
PORT=3000

# WhatsApp Cloud API (from Meta Developer Dashboard)
WHATSAPP_PHONE_NUMBER_ID=your_15_digit_phone_number_id
WHATSAPP_WABA_ID=your_waba_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose

# Supabase (from Supabase project settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LLM (add later when LLM is decided)
# ANTHROPIC_API_KEY=sk-ant-...
